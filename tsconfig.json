{
  "extends": "@homebound/tsconfig/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["vitest/globals", "node"],
    "jsx": "react-jsx",
    "module": "Preserve",
    // Let tsup rewrite path-less imports
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true
  }
}
