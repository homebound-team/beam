{
  "name": "@homebound/beam",
  "version": "3.0.0-alpha.1",
  "type": "module",
  "author": "Homebound",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/homebound-team/beam"
  },
  "files": [
    "dist",
    "!dist/**/*.{stories,test}.*",
    "!dist/setupTests.*"
  ],
  "engines": {
    "node": "~22.14.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./rtl": {
      "types": "./dist/utils/rtlUtils.d.ts",
      "import": "./dist/utils/rtlUtils.js",
      "require": "./dist/utils/rtlUtils.cjs"
    },
    "./index.css": "./dist/index.css"
  },
  "scripts": {
    "start": "yarn storybook",
    "build": "yarn tsup-node src/index.ts src/utils/rtlUtils.tsx --format esm,cjs --dts --clean --sourcemap",
    "build:truss": "truss",
    "build-storybook": "NODE_OPTIONS=--openssl-legacy-provider storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext js,ts,tsx src",
    "lint:fix": "eslint --ext js,ts,tsx --fix src",
    "storybook": "NODE_OPTIONS=--openssl-legacy-provider storybook dev -p 9000",
    "chromatic": "chromatic --project-token=074248da7284 --exit-once-uploaded --only-changed",
    "copy": "npx copyfiles -u 1 \"./src/**/*.css\" \"./dist/\"",
    "copy-to-internal-frontend": "cp -r dist/* ~/homebound/internal-frontend/node_modules/@homebound/beam/dist/",
    "format": "prettier --loglevel warn --write \"**/*.{ts,tsx,css,md,mdx}\"",
    "type-check": "yarn tsc"
  },
  "dependencies": {
    "@homebound/form-state": "^2.28.0",
    "@internationalized/number": "^3.0.3",
    "@popperjs/core": "^2.11.6",
    "@react-aria/utils": "^3.33.1",
    "change-case": "^5.4.4",
    "date-fns": "^2.28.0",
    "dompurify": "^2.3.0",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^9.0.4",
    "memoize-one": "^5.2.1",
    "mobx-utils": "^6.1.1",
    "react-aria": "^3.47.0",
    "react-day-picker": "8.0.7",
    "react-popper": "^2.3.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "react-stately": "^3.45.0",
    "react-virtuoso": "^4.2.2",
    "tributejs": "^5.1.3",
    "trix": "^1.3.1",
    "use-debounce": "^10.0.4",
    "use-query-params": "^2.2.2"
  },
  "peerDependencies": {
    "mobx-react": ">=7",
    "react": ">=16",
    "react-router-dom": ">=5.2"
  },
  "peerDependenciesMeta": {
    "mobx-react": {
      "optional": true
    },
    "react-router-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@homebound/eslint-config": "^1.10.2",
    "@homebound/rtl-react-router-utils": "1.3.0",
    "@homebound/rtl-utils": "^2.70.0",
    "@homebound/truss": "^2.2.2",
    "@homebound/tsconfig": "^1.1.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-links": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/recommended": "^1.0.13",
    "@types/dompurify": "^2.2.3",
    "@types/node": "^22.10.10",
    "@types/react": "^18.3.11",
    "@types/react-beautiful-dnd": "^13.1.3",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "array-move": "^4.0.0",
    "chromatic": "^15.3.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^8.52.0",
    "eslint-plugin-storybook": "^10.2.19",
    "husky": "^5.1.1",
    "jsdom": "^29.0.0",
    "mobx": "^6.15.0",
    "mobx-react": "^9.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "semantic-release": "^24.2.9",
    "storybook": "^10.2.19",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "watch": "^1.0.2"
  },
  "resolutions": {
    "@types/react": "18.0.28",
    "react-router": "5.3.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0"
  },
  "imports": {
    "src/*": "./src/*"
  },
  "packageManager": "yarn@4.13.0"
}
